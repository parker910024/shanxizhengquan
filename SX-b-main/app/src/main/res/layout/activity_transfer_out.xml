<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".ui.transfer.TransferOutActivity">

    <include
        android:id="@+id/title_bar"
        layout="@layout/include_title_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/title_bar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp">

            <!-- 行：左标签 右数值，与参考图一致 -->
            <!-- T+1资金（红色数值） -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="T+1资金"
                    android:textColor="@color/text_selected_color"
                    android:textSize="15sp" />
                <TextView
                    android:id="@+id/tv_t1_funds"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/user_red_primary"
                    android:textSize="15sp" />
            </LinearLayout>

            <!-- 可转出金额 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="可转出金额"
                    android:textColor="@color/text_selected_color"
                    android:textSize="15sp" />
                <TextView
                    android:id="@+id/tv_transferable_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.00"
                    android:textColor="@color/text_selected_color"
                    android:textSize="15sp" />
            </LinearLayout>

            <!-- 银行卡（卡号 + >） -->
            <LinearLayout
                android:id="@+id/row_bank_card"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="银行卡"
                    android:textColor="@color/text_selected_color"
                    android:textSize="15sp" />
                <TextView
                    android:id="@+id/tv_bank_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:gravity="end"
                    android:maxLines="1"
                    android:text="请先绑定银行卡"
                    android:textColor="@color/text_second_color"
                    android:textSize="15sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text=">"
                    android:textColor="@color/text_second_color"
                    android:textSize="15sp" />
            </LinearLayout>

            <!-- 转出金额（左标签，右输入框，占位符 转出金额 ¥） -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="转出金额"
                    android:textColor="@color/text_selected_color"
                    android:textSize="15sp" />
                <EditText
                    android:id="@+id/et_amount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:background="@null"
                    android:hint="转出金额 ¥"
                    android:inputType="numberDecimal"
                    android:paddingVertical="8dp"
                    android:textColor="@color/text_selected_color"
                    android:textColorHint="@color/text_second_color"
                    android:textSize="15sp" />
            </LinearLayout>

            <!-- 最小转出金额提示（浅灰） -->
            <TextView
                android:id="@+id/tv_min_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="4dp"
                android:text="最小转出金额100"
                android:textColor="@color/text_second_color"
                android:textSize="12sp" />

            <!-- 全部提现 -->
            <TextView
                android:id="@+id/tv_withdraw_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:text="全部提现"
                android:textColor="@color/user_red_primary"
                android:textSize="14sp" />

            <!-- 转出按钮 -->
            <Button
                android:id="@+id/btn_transfer_out"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_btn_red"
                android:text="转出"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- 分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="8dp"
                android:background="#F5F5F5" />

            <!-- 转出记录标题 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="4dp"
                android:text="转出记录"
                android:textColor="@color/text_selected_color"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- 转出记录列表 -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_records"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_fund_record" />

            <!-- 空状态 -->
            <TextView
                android:id="@+id/tv_records_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingVertical="32dp"
                android:text="暂无转出记录"
                android:textColor="@color/text_second_color"
                android:textSize="14sp"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
