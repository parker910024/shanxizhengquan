<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- 标题栏 -->
    <include
        android:id="@+id/title_bar"
        layout="@layout/include_title_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 日期切换栏：与 iOS 一致 高度 40dp、左右 16dp，箭头点击区域 ≥44dp -->
    <LinearLayout
        android:id="@+id/layout_date_picker"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_dragon_date_bar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/title_bar">

        <ImageButton
            android:id="@+id/btn_prev_date"
            android:layout_width="44dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="上一天"
            android:src="@drawable/ic_arrow_left" />

        <LinearLayout
            android:id="@+id/layout_date_center"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/tv_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#333333"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:text="2026-01-28" />

            <ImageView
                android:id="@+id/iv_calendar"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="6dp"
                android:contentDescription="选择日期"
                android:src="@drawable/ic_calendar" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_next_date"
            android:layout_width="44dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="下一天"
            android:src="@drawable/ic_arrow_right" />

    </LinearLayout>

    <!-- 列头：与 iOS 一致 名称(左) | 收盘(52dp 右) | 净买入(68dp 右) | 涨跌幅(52dp 右)，左右 14dp -->
    <LinearLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="12dp"
        android:paddingBottom="6dp"
        android:gravity="center_vertical"
        android:background="@color/white"
        app:layout_constraintTop_toBottomOf="@id/layout_date_picker">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="名称"
            android:textColor="#666666"
            android:textSize="12sp"
            android:gravity="start" />

        <TextView
            android:layout_width="52dp"
            android:layout_height="wrap_content"
            android:text="收盘"
            android:textColor="#666666"
            android:textSize="12sp"
            android:gravity="end" />

        <TextView
            android:layout_width="8dp"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="68dp"
            android:layout_height="wrap_content"
            android:text="净买入"
            android:textColor="#666666"
            android:textSize="12sp"
            android:gravity="end" />

        <TextView
            android:layout_width="8dp"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="52dp"
            android:layout_height="wrap_content"
            android:text="涨跌幅"
            android:textColor="#666666"
            android:textSize="12sp"
            android:gravity="end" />

    </LinearLayout>

    <!-- 分割线（设计稿 #E0E0E0） -->
    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        app:layout_constraintTop_toBottomOf="@id/layout_header" />

    <!-- 数据列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_dragon_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/white"
        app:layout_constraintBottom_toTopOf="@id/nav_bar"
        app:layout_constraintTop_toBottomOf="@id/divider"
        tools:listitem="@layout/item_dragon" />

    <!-- 加载中 -->
    <ProgressBar
        android:id="@+id/progress_dragon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/nav_bar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divider" />

    <!-- 空状态 -->
    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/dragon_empty"
        android:textColor="#999999"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/nav_bar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divider" />

    <ex.ss.lib.base.view.ImmersiveNavigationBarHolder
        android:id="@+id/nav_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
