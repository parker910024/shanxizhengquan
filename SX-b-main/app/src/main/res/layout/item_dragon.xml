<?xml version="1.0" encoding="utf-8"?>
<!-- 列表项：与 iOS 一致 行高 48dp，名称 14sp bold、代码 11sp、收盘/净买入/涨跌幅 13sp -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="48dp"
    android:background="@color/white"
    android:orientation="vertical">

    <!-- 与 iOS 一致：名称(左 pad 14) | 收盘(52dp 右) | 净买入(68dp 右) | 涨跌幅(52dp 右)，列间距 8dp -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingVertical="12dp"
        android:gravity="center_vertical"
        android:minHeight="48dp">

        <!-- 名称 + 代码 + 市场 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#343434"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="贵州茅台" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_code"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#989898"
                    android:textSize="11sp"
                    tools:text="600519" />

                <TextView
                    android:id="@+id/tv_market"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_market_tag"
                    android:paddingHorizontal="4dp"
                    android:paddingVertical="2dp"
                    android:textColor="#989898"
                    android:textSize="10sp"
                    android:visibility="gone"
                    tools:text="沪"
                    tools:visibility="visible" />
            </LinearLayout>
        </LinearLayout>

        <!-- 收盘 52dp 右对齐 -->
        <TextView
            android:id="@+id/tv_close_price"
            android:layout_width="52dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:textColor="#343434"
            android:textSize="13sp"
            android:textStyle="bold"
            tools:text="1425.00" />

        <View
            android:layout_width="8dp"
            android:layout_height="0dp" />

        <!-- 净买入 68dp 右对齐 -->
        <TextView
            android:id="@+id/tv_net_buy"
            android:layout_width="68dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:textColor="#E05A55"
            android:textSize="13sp"
            tools:text="1.23亿" />

        <View
            android:layout_width="8dp"
            android:layout_height="0dp" />

        <!-- 涨跌幅 52dp 右对齐 -->
        <TextView
            android:id="@+id/tv_change_pct"
            android:layout_width="52dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:textColor="#E05A55"
            android:textSize="13sp"
            tools:text="+2.35%" />
    </LinearLayout>

    <!-- 行间分割线（设计稿 1px #E0E0E0） -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0" />
</LinearLayout>
